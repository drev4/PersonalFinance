    "@finanzas/shared": "workspace:*",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.0.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.3.0",
    "fastify": "^4.25.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "node-cron": "^3.0.3",
