{
  "name": "@finanzas/api",
  "version": "0.1.0",
  "description": "Fastify backend for Finanzas app",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
