{
  "private": true,
  "name": "finanzas-app",
  "version": "0.1.0",
  "description": "Personal finance management app",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "lsof -ti:3001,5173 | xargs kill -9 2>/dev/null; pnpm --filter=api --filter=web --parallel run dev",
    "dev:win": "powershell -Command \"@(3001,5173) | ForEach-Object { $p = (Get-NetTCPConnection -LocalPort $_ -ErrorAction SilentlyContinue).OwningProcess; if($p) { Stop-Process -Id $p -Force } }; pnpm --filter=api --filter=web --parallel run dev\"",
    "dev:mobile": "pnpm --filter=@finanzas/mobile run dev",
    "mobile:ios": "pnpm --filter=@finanzas/mobile run ios",
    "mobile:android": "pnpm --filter=@finanzas/mobile run android",
    "mobile:build": "pnpm --filter=@finanzas/mobile run build",
    "mobile:typecheck": "pnpm --filter=@finanzas/mobile run typecheck",
    "mobile:lint": "pnpm --filter=@finanzas/mobile run lint",
    "mobile:eas-login": "cd packages/mobile && npx eas-cli login",
    "mobile:eas-init": "cd packages/mobile && npx eas-cli init",
    "build": "pnpm --filter=./packages run build",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}